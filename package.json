{
  "name": "navi",
  "version": "1.0.0",
  "description": "AI screen guide that shows you where to go",
  "author": "Navi",
  "main": "src/main.js",
  "scripts": {
    "test": "node --test",
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win --x64"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.navi.app",
    "productName": "Navi",
    "copyright": "Copyright 2025",
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Navi"
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/@xenova/transformers/**/*"
    ],
    "npmRebuild": false,
    "files": [
      "src/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    }
  }
}
